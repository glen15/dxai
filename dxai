#!/bin/bash
# dxai - Main CLI entrypoint.
# Routes subcommands and interactive menu.
# Handles update/remove flows.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/core/common.sh"
source "$SCRIPT_DIR/lib/core/commands.sh"

trap cleanup_temp_files EXIT INT TERM

# Version and update helpers
VERSION="1.29.0"
DXAI_TAGLINE="Deep clean and optimize your Mac."

is_touchid_configured() {
    local pam_sudo_file="/etc/pam.d/sudo"
    [[ -f "$pam_sudo_file" ]] && grep -q "pam_tid.so" "$pam_sudo_file" 2> /dev/null
}

get_latest_version() {
    curl -fsSL --connect-timeout 2 --max-time 3 -H "Cache-Control: no-cache" \
        "https://raw.githubusercontent.com/glen15/dxai/main/dxai" 2> /dev/null |
        grep '^VERSION=' | head -1 | sed 's/VERSION="\(.*\)"/\1/'
}

get_latest_version_from_github() {
    local version
    version=$(curl -fsSL --connect-timeout 2 --max-time 3 \
        "https://api.github.com/repos/glen15/dxai/releases/latest" 2> /dev/null |
        grep '"tag_name"' | head -1 | sed -E 's/.*"([^"]+)".*/\1/')
    version="${version#v}"
    version="${version#V}"
    echo "$version"
}

get_homebrew_latest_version() {
    command -v brew > /dev/null 2>&1 || return 1

    local line candidate=""

    # Prefer local tap outdated info to avoid notifying before formula is available.
    line=$(HOMEBREW_NO_AUTO_UPDATE=1 brew outdated --formula --verbose dxai 2> /dev/null | head -1 || true)
    if [[ "$line" == *"< "* ]]; then
        candidate="${line##*< }"
        candidate="${candidate%% *}"
    fi

    # Fallback for environments where outdated output is unavailable.
    if [[ -z "$candidate" ]]; then
        line=$(HOMEBREW_NO_AUTO_UPDATE=1 brew info dxai 2> /dev/null | awk 'NR==1 { print; exit }' || true)
        line="${line#==> }"
        line="${line#*: }"
        if [[ "$line" == stable* ]]; then
            candidate=$(printf '%s\n' "$line" | awk '{print $2}')
        fi
    fi

    [[ -n "$candidate" ]] && printf '%s\n' "$candidate"
}
# Install detection (Homebrew vs manual).
# Uses variable capture + string matching to avoid SIGPIPE under pipefail.
is_homebrew_install() {
    local dxai_path link_target has_brew=false
    dxai_path=$(command -v dxai 2> /dev/null) || return 1

    if command -v brew > /dev/null 2>&1; then
        has_brew=true
    fi

    if [[ -L "$dxai_path" ]]; then
        link_target=$(readlink "$dxai_path" 2> /dev/null) || true
        if [[ "$link_target" == *"Cellar/dxai"* ]]; then
            if $has_brew; then
                brew list dxai > /dev/null 2>&1 && return 0
            fi
            return 1
        fi
    fi

    if [[ -f "$dxai_path" ]]; then
        case "$dxai_path" in
            /opt/homebrew/bin/dxai | /usr/local/bin/dxai)
                if [[ -d /opt/homebrew/Cellar/dxai ]] || [[ -d /usr/local/Cellar/dxai ]]; then
                    if $has_brew; then
                        brew list dxai > /dev/null 2>&1 && return 0
                    else
                        return 0 # Cellar exists, probably Homebrew install
                    fi
                fi
                ;;
        esac
    fi

    if $has_brew; then
        local brew_prefix
        brew_prefix=$(brew --prefix 2> /dev/null)
        if [[ -n "$brew_prefix" && "$dxai_path" == "$brew_prefix/bin/dxai" && -d "$brew_prefix/Cellar/dxai" ]]; then
            brew list dxai > /dev/null 2>&1 && return 0
        fi
    fi

    return 1
}

get_install_channel() {
    # Try user config dir first (matches install.sh behavior), fallback to SCRIPT_DIR
    local channel_file="${DXAI_CONFIG_DIR:-$HOME/.config/dxai}/install_channel"
    if [[ ! -f "$channel_file" ]]; then
        channel_file="$SCRIPT_DIR/install_channel"
    fi
    local channel="stable"
    if [[ -f "$channel_file" ]]; then
        channel=$(sed -n 's/^CHANNEL=\(.*\)$/\1/p' "$channel_file" | head -1)
    fi
    case "$channel" in
        nightly | dev | stable) printf '%s\n' "$channel" ;;
        *) printf 'stable\n' ;;
    esac
}

get_install_commit() {
    # Try user config dir first (matches install.sh behavior), fallback to SCRIPT_DIR
    local channel_file="${DXAI_CONFIG_DIR:-$HOME/.config/dxai}/install_channel"
    if [[ ! -f "$channel_file" ]]; then
        channel_file="$SCRIPT_DIR/install_channel"
    fi
    if [[ -f "$channel_file" ]]; then
        sed -n 's/^COMMIT_HASH=\(.*\)$/\1/p' "$channel_file" | head -1
    fi
}

# Background update notice
check_for_updates() {
    local msg_cache="$HOME/.cache/dxai/update_message"
    ensure_user_dir "$(dirname "$msg_cache")"
    ensure_user_file "$msg_cache"

    (
        (
            local latest

            latest=$(get_latest_version_from_github)
            if [[ -z "$latest" ]]; then
                latest=$(get_latest_version)
            fi

            if [[ -n "$latest" && "$VERSION" != "$latest" && "$(printf '%s\n' "$VERSION" "$latest" | sort -V | head -1)" == "$VERSION" ]]; then
                if is_homebrew_install; then
                    # For Homebrew, only notify if the brew tap has the new version available locally
                    local brew_latest
                    brew_latest=$(get_homebrew_latest_version || true)
                    if [[ -n "$brew_latest" && "$brew_latest" != "$VERSION" && "$(printf '%s\n' "$VERSION" "$brew_latest" | sort -V | head -1)" == "$VERSION" ]]; then
                        printf "\nUpdate %s available, run %sdxai update%s\n\n" "$brew_latest" "$GREEN" "$NC" > "$msg_cache"
                    else
                        echo -n > "$msg_cache"
                    fi
                else
                    printf "\nUpdate %s available, run %sdxai update%s\n\n" "$latest" "$GREEN" "$NC" > "$msg_cache"
                fi
            else
                echo -n > "$msg_cache"
            fi
        ) > /dev/null 2>&1 < /dev/null &
    )
}

show_update_notification() {
    local msg_cache="$HOME/.cache/dxai/update_message"
    if [[ -f "$msg_cache" && -s "$msg_cache" ]]; then
        cat "$msg_cache"
        echo
    fi
}

# UI helpers
show_brand_banner() {
    cat << 'BANNER'

BANNER
    printf "${GREEN}  ____  __  __    _    ___  ${NC}\n"
    printf "${GREEN} |  _ \\ \\ \\/ /   / \\  |_ _| ${NC}\n"
    printf "${GREEN} | | | | \\  /   / _ \\  | |  ${NC}\n"
    printf "${GREEN} | |_| | /  \\  / ___ \\ | |  ${NC}  ${BLUE}https://github.com/glen15/dxai${NC}\n"
    printf "${GREEN} |____/ /_/\\_\\/_/   \\_\\___| ${NC}  ${GREEN}${DXAI_TAGLINE}${NC}\n"
    echo ""
}

show_version() {
    local os_ver
    if command -v sw_vers > /dev/null; then
        os_ver=$(sw_vers -productVersion)
    else
        os_ver="Unknown"
    fi

    local arch
    arch=$(uname -m)

    local kernel
    kernel=$(uname -r)

    local sip_status
    if command -v csrutil > /dev/null; then
        sip_status=$(csrutil status 2> /dev/null | grep -o "enabled\|disabled" || echo "Unknown")
        sip_status="$(LC_ALL=C tr '[:lower:]' '[:upper:]' <<< "${sip_status:0:1}")${sip_status:1}"
    else
        sip_status="Unknown"
    fi

    local disk_free
    disk_free=$(df -h / 2> /dev/null | awk 'NR==2 {print $4}' || echo "Unknown")

    local install_method="Manual"
    if is_homebrew_install; then
        install_method="Homebrew"
    fi

    local channel
    channel=$(get_install_channel)

    printf '\ndxai version %s\n' "$VERSION"
    if [[ "$channel" == "nightly" ]]; then
        local commit
        commit=$(get_install_commit)
        if [[ -n "$commit" ]]; then
            printf 'Channel: Nightly (%s)\n' "$commit"
        else
            printf 'Channel: Nightly\n'
        fi
    fi
    printf 'macOS: %s\n' "$os_ver"
    printf 'Architecture: %s\n' "$arch"
    printf 'Kernel: %s\n' "$kernel"
    printf 'SIP: %s\n' "$sip_status"
    printf 'Disk Free: %s\n' "$disk_free"
    printf 'Install: %s\n' "$install_method"
    printf 'Shell: %s\n\n' "${SHELL:-Unknown}"
}

